APP_DEBUG = true
APP_TRACE = false

# 数据库配置
DB_DRIVER = mysql
DB_HOST = 127.0.0.1
DB_PORT = 3306
DB_DATABASE = app_management
DB_USERNAME = root
DB_PASSWORD =
DB_CHARSET = utf8mb4
DB_DEBUG = true

# JWT 配置
JWT_SECRET = your_jwt_secret_key_here_change_in_production
JWT_EXPIRE = 604800

# 文件上传配置
UPLOAD_PATH = /uploads
APK_UPLOAD_DIR = /uploads/apk
ICON_UPLOAD_DIR = /uploads/icons
MAX_UPLOAD_SIZE = 1024000000

# 应用配置
APP_NAME = AppManagement
APP_VERSION = 1.0.0
