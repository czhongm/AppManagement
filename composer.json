{
  "name": "czhongm/app-management",
  "description": "App升级管理后台 - ThinkPHP版",
  "type": "project",
  "license": "MIT",
  "authors": [
    {
      "name": "czhongm"
    }
  ],
  "require": {
    "php": ">=7.4",
    "topthink/framework": "^6.0",
    "topthink/think-orm": "^3.0",
    "firebase/php-jwt": "^6.0"
  },
  "require-dev": {
    "topthink/think-testing": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "app\\": "app"
    }
  },
  "scripts": {
    "post-install-cmd": [
      "@php think migrate:run --seed"
    ]
  },
  "config": {
    "optimize-autoloader": true,
    "process-timeout": 0
  }
}
